@page
@model IndexModel
@{
    ViewData["Title"] = "控制台";
}

<section class="workspace-shell">
    <div class="workspace-header">
        <div>
            <p class="eyebrow">Boxmaker Server</p>
            <h1>盒造再生控制台</h1>
        </div>
        <div id="sessionBadge" class="session-badge">未登录</div>
    </div>

    <div class="workspace-grid">
        <section class="panel account-panel">
            <div class="panel-heading">
                <h2>账号</h2>
                <button id="logoutButton" class="icon-button hidden" title="退出登录" type="button">↩</button>
            </div>

            <form id="loginForm" class="stack">
                <label>
                    OpenID
                    <input id="openidInput" name="openid" autocomplete="username" />
                </label>
                <label>
                    密码
                    <input id="openkeyInput" name="openkey" type="password" autocomplete="current-password" />
                </label>
                <button type="submit">登录</button>
            </form>

            <div id="profilePane" class="hidden stack">
                <div class="identity-row">
                    <div class="avatar" id="avatarBox">0</div>
                    <div>
                        <h3 id="playerName">-</h3>
                        <p id="playerMeta">-</p>
                    </div>
                </div>

                <div class="stat-grid">
                    <div><span id="levelValue">0</span><small>等级</small></div>
                    <div><span id="nextExpValue">0</span><small>下一级</small></div>
                    <div><span id="amountValue">0</span><small>游玩</small></div>
                    <div><span id="pasValue">0</span><small>通关</small></div>
                    <div><span id="commentValue">0</span><small>评论</small></div>
                    <div><span id="watchedValue">0</span><small>录像观看</small></div>
                </div>

                <form id="profileForm" class="compact-form">
                    <input id="nicknameInput" placeholder="名称" />
                    <input id="nationalityInput" placeholder="地区" />
                    <input id="headInput" type="number" min="0" step="1" placeholder="头像" />
                    <button type="submit">保存资料</button>
                </form>

                <form id="passwordForm" class="compact-form">
                    <input id="oldPasswordInput" type="password" placeholder="当前密码" autocomplete="current-password" />
                    <input id="newPasswordInput" type="password" placeholder="新密码" autocomplete="new-password" />
                    <button type="submit">更改密码</button>
                </form>
            </div>
        </section>

        <section class="panel map-panel">
            <div class="panel-heading">
                <h2>地图搜索</h2>
                <span id="mapCountLabel">0</span>
            </div>
            <form id="searchForm" class="search-bar">
                <input id="mapSearchInput" placeholder="地图名、作者或 ID" />
                <button type="submit">搜索</button>
            </form>
            <div id="mapResults" class="map-results"></div>
        </section>
    </div>
</section>

@section Scripts {
    <script>
        window.boxmakerInitialUser = @Html.Raw(Model.InitialUserJson);
    </script>
}
